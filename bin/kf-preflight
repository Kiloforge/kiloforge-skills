#!/bin/sh
# kf-preflight — Verify Kiloforge is initialized before running any skill.
#
# Checks that required metadata files and CLI tools exist on the primary
# branch. Run this at the start of every kf-* skill.
#
# USAGE:
#   eval "$(.agent/kf/bin/kf-preflight)"
#
# On success: prints PRIMARY_BRANCH=<branch> for eval
# On failure: prints error message to stderr and exits with code 1
#
# CHECKS:
#   1. Resolves primary branch
#   2. Verifies required metadata files exist on primary branch
#   3. Verifies CLI tools are installed locally

set -eu

KF_BIN="$(cd "$(dirname "$0")" && pwd)"

# ── Resolve primary branch ───────────────────────────────────────────────────
PRIMARY_BRANCH=$("$KF_BIN/kf-primary-branch")

# ── Check required metadata files on primary branch ──────────────────────────
MISSING=""
for file in \
  .agent/kf/config.yaml \
  .agent/kf/product.yaml \
  .agent/kf/tech-stack.yaml \
  .agent/kf/workflow.yaml \
  .agent/kf/tracks.yaml \
; do
  if ! git show "${PRIMARY_BRANCH}:${file}" >/dev/null 2>&1; then
    MISSING="$MISSING  - $file\n"
  fi
done

if [ -n "$MISSING" ]; then
  echo "ERROR: Kiloforge is not initialized. Missing files on ${PRIMARY_BRANCH}:" >&2
  printf "$MISSING" >&2
  echo "" >&2
  echo "Run /kf-setup to initialize Kiloforge for this project." >&2
  exit 1
fi

# ── Check CLI tools exist locally ────────────────────────────────────────────
MISSING_TOOLS=""
for tool in kf-primary-branch kf-track kf-track-content kf-merge kf-merge-lock; do
  if [ ! -x "$KF_BIN/$tool" ]; then
    MISSING_TOOLS="$MISSING_TOOLS  - $tool\n"
  fi
done

if [ -n "$MISSING_TOOLS" ]; then
  echo "WARNING: Missing CLI tools in .agent/kf/bin/:" >&2
  printf "$MISSING_TOOLS" >&2
  echo "Re-run /kf-setup to install tools." >&2
  # Warning only — don't block, some tools may not be needed
fi

# ── Output for eval ──────────────────────────────────────────────────────────
echo "PRIMARY_BRANCH=$PRIMARY_BRANCH"
