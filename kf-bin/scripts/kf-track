#!/usr/bin/env bash
set -euo pipefail

# kf-track — Track registry management tool for Kiloforge agents.
#
# Operates on tracks.yaml (track registry) and deps.yaml (dependency graph).
# Designed for use by both humans and AI agents.
#
# TRACKS.YAML FORMAT:
#   Each line: <track-id>: {"title":"...","status":"...","type":"...","created":"...","updated":"..."}
#   Track ID is always the leftmost field for human readability.
#   Status values: pending, in-progress, completed, archived
#
# DEPS.YAML FORMAT:
#   Each track ID maps to a list of prerequisite track IDs.
#   See deps.yaml header for full protocol.

# --- Config ---
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
KF_DIR="${SCRIPT_DIR%/bin}"
TRACKS_FILE="${KF_DIR}/tracks.yaml"
DEPS_FILE="${KF_DIR}/tracks/deps.yaml"
CONFLICTS_FILE="${KF_DIR}/tracks/conflicts.yaml"

# --- Platform detection ---
# Detect OS for platform-specific behavior (sed -i, etc.)
_KF_OS="$(uname -s 2>/dev/null || echo Unknown)"
case "$_KF_OS" in
  Darwin*)  _KF_PLATFORM="mac" ;;
  Linux*)   _KF_PLATFORM="linux" ;;
  MINGW*|MSYS*|CYGWIN*) _KF_PLATFORM="windows" ;;
  *)        _KF_PLATFORM="unknown" ;;
esac

# Platform-portable sed in-place: `sedi 'pattern' file`
sedi() {
  if [[ "$_KF_PLATFORM" == "mac" ]]; then
    sed -i '' "$@"
  else
    sed -i "$@"
  fi
}

# --- Prerequisite checks ---
# Python3 is required for kf-track-content (structured YAML management).
# jq is strongly recommended for canonical JSON ordering.
_check_prerequisites() {
  local missing=()
  if ! command -v python3 &>/dev/null; then
    missing+=("python3 (required for track content management: init, show, spec, plan, task, progress, migrate)")
  fi
  if ! command -v jq &>/dev/null; then
    missing+=("jq (recommended for canonical JSON field ordering — without it, field order in tracks.yaml may vary)")
  fi
  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "WARNING: Missing tool(s):" >&2
    for m in "${missing[@]}"; do
      echo "  - $m" >&2
    done
    echo "" >&2
  fi
}

# Run prereq check once at startup (only warns, does not block)
_check_prerequisites

# --- Helpers ---
now_iso() { date -u +%Y-%m-%dT%H:%M:%SZ; }
today_iso() { date -u +%Y-%m-%d; }

# Canonical JSON field order for tracks.yaml.
# All writes go through this to keep diffs stable and predictable.
# Order: title, status, type, created, updated, [archived_at, archive_reason]
normalize_json() {
  # Usage: normalize_json '{"status":"pending","title":"Foo",...}'
  # Outputs: {"title":"Foo","status":"pending",...} with canonical key order
  local json="$1"
  if command -v jq &>/dev/null; then
    echo "$json" | jq -c '{
      title: .title,
      status: .status,
      type: .type,
      created: .created,
      updated: .updated
    } + (if .archived_at then {archived_at: .archived_at} else {} end)
      + (if .archive_reason then {archive_reason: .archive_reason} else {} end)
      + (to_entries | map(select(.key | IN("title","status","type","created","updated","archived_at","archive_reason") | not)) | from_entries)'
  else
    # Without jq, return as-is (best-effort — jq strongly recommended)
    echo "$json"
  fi
}

# --- Claim detection ---
# Scan git branches for implementation branches and return claimed track IDs.
# Output: one line per claimed track — "trackId workerName" (tab-separated).
# workerName is extracted from worktree folder name if identifiable.
branch_scan_claimed() {
  local branches
  branches=$(git branch --list 'feature/*' 'bug/*' 'chore/*' 'refactor/*' 2>/dev/null | sed 's/^[* ]*//' || true)
  [[ -z "$branches" ]] && return
  local worktree_map=""
  worktree_map=$(git worktree list 2>/dev/null | awk '{print $3, $1}' | sed 's/\[//;s/\]//' || true)
  while IFS= read -r branch; do
    # Extract track ID: strip type prefix (feature/, chore/, etc.)
    local track_id
    track_id=$(echo "$branch" | sed 's|^[^/]*/||')
    # Find which worktree (if any) has this branch checked out
    local worker=""
    if [[ -n "$worktree_map" ]]; then
      local wt_path
      wt_path=$(echo "$worktree_map" | awk -v b="$branch" '$1 == b {print $2}')
      if [[ -n "$wt_path" ]]; then
        worker=$(basename "$wt_path")
      fi
    fi
    printf "%s\t%s\n" "$track_id" "$worker"
  done <<< "$branches"
}

# Query orchestrator claim API for claimed tracks.
# Falls back to empty output if server is unreachable.
server_query_claims() {
  local orch_url="${KF_ORCH_URL:-http://localhost:39517}"
  local response
  response=$(curl -sf --max-time 1 "${orch_url}/api/tracks/claims" 2>/dev/null) || return 0
  # Expected JSON: [{"track_id":"...","worker":"..."},...]
  if command -v jq &>/dev/null; then
    echo "$response" | jq -r '.[] | "\(.track_id)\t\(.worker // "")"' 2>/dev/null || true
  fi
}

# Get claimed tracks: try server first, fall back to branch scan.
# Output: one line per claimed track — "trackId\tworkerName"
get_claimed_tracks() {
  local claims
  claims=$(server_query_claims)
  if [[ -z "$claims" ]]; then
    claims=$(branch_scan_claimed)
  fi
  echo "$claims"
}

# Check if a specific track is claimed. Returns 0 if claimed, 1 if not.
# Sets CLAIMED_BY variable with worker name if claimed.
is_track_claimed() {
  local track_id="$1"
  local claims
  claims=$(get_claimed_tracks)
  [[ -z "$claims" ]] && return 1
  local match
  match=$(echo "$claims" | awk -F'\t' -v id="$track_id" '$1 == id {print $2; exit}')
  if [[ -n "$match" || $(echo "$claims" | awk -F'\t' -v id="$track_id" '$1 == id {found=1} END{print found+0}') -eq 1 ]]; then
    CLAIMED_BY="$match"
    return 0
  fi
  return 1
}

# Sort tracks.yaml lines by track ID (alphabetical) while preserving header comments.
sort_tracks_file() {
  if [[ ! -f "$TRACKS_FILE" ]]; then return; fi
  local header data
  header=$(grep "^#" "$TRACKS_FILE" || true)
  data=$(grep -v "^#" "$TRACKS_FILE" | grep -v "^$" | LC_ALL=C sort || true)
  {
    echo "$header"
    [[ -n "$data" ]] && echo "" && echo "$data"
  } > "${TRACKS_FILE}.tmp"
  mv "${TRACKS_FILE}.tmp" "$TRACKS_FILE"
}

# Sort deps.yaml: entries alphabetical by track ID, dep lists sorted within each.
# Uses Python for reliable multi-line YAML block sorting; falls back to no-sort.
sort_deps_file() {
  [[ ! -f "$DEPS_FILE" ]] && return
  if command -v python3 &>/dev/null; then
    python3 -c "
import re, sys
text = open(sys.argv[1]).read()
# Split header (comment lines at top) from entries
lines = text.split('\n')
header, rest = [], []
in_header = True
for l in lines:
    if in_header and (l.startswith('#') or l.strip() == ''):
        header.append(l)
    else:
        in_header = False
        rest.append(l)
# Parse entries: each starts with a non-space, non-# line
entries = {}
current_id = None
for l in rest:
    if l and not l.startswith(' ') and not l.startswith('#'):
        current_id = l.split(':')[0]
        if '[]' in l:
            entries[current_id] = []
        else:
            entries[current_id] = []
    elif l.startswith('  - ') and current_id:
        entries[current_id].append(l.replace('  - ', '', 1))
# Write sorted
out = '\n'.join(header).rstrip() + '\n\n'
for tid in sorted(entries.keys()):
    deps = sorted(entries[tid])
    if not deps:
        out += f'{tid}: []\n'
    else:
        out += f'{tid}:\n'
        for d in deps:
            out += f'  - {d}\n'
    out += '\n'
open(sys.argv[1], 'w').write(out.rstrip() + '\n')
" "$DEPS_FILE"
  fi
}

ensure_tracks_file() {
  if [[ ! -f "$TRACKS_FILE" ]]; then
    cat > "$TRACKS_FILE" <<'HEADER'
# Kiloforge Track Registry
#
# FORMAT: <track-id>: {"title":"...","status":"...","type":"...","created":"...","updated":"..."}
# STATUS: pending | in-progress | completed | archived
# ORDER:  Lines sorted alphabetically by track ID. JSON fields in canonical order:
#         title, status, type, created, updated [, archived_at, archive_reason]
# TOOL:   Use `kf-track` to manage entries. Do not edit by hand.
#
HEADER
  fi
}

ensure_deps_file() {
  if [[ ! -f "$DEPS_FILE" ]]; then
    mkdir -p "$(dirname "$DEPS_FILE")"
    cat > "$DEPS_FILE" <<HEADER
# Track Dependency Graph
#
# PROTOCOL:
#   Canonical source for track dependency ordering (adjacency list).
#   Each key is a track ID; its value is a list of prerequisite track IDs.
#
# RULES:
#   - Only pending/in-progress tracks listed. Completed tracks pruned on cleanup.
#   - Architect appends entries when creating tracks.
#   - Developer checks deps before claiming: all deps must be completed.
#   - Cycles are forbidden.
#
# UPDATED: $(now_iso)
HEADER
  fi
}

track_exists() {
  grep -q "^${1}:" "$TRACKS_FILE" 2>/dev/null
}

get_track_line() {
  grep "^${1}:" "$TRACKS_FILE" 2>/dev/null
}

get_track_json() {
  local line
  line=$(get_track_line "$1") || return 1
  echo "$line" | sed "s/^[^{]*//"
}

get_field() {
  # Usage: get_field <track-id> <field>
  local json
  json=$(get_track_json "$1") || return 1
  if command -v jq &>/dev/null; then
    echo "$json" | jq -r ".$2 // empty"
  else
    # Fallback: basic grep for "field":"value"
    echo "$json" | grep -o "\"$2\":\"[^\"]*\"" | head -1 | sed 's/.*:"\(.*\)"/\1/'
  fi
}

set_field() {
  # Usage: set_field <track-id> <field> <value>
  local id="$1" field="$2" value="$3"
  local json
  json=$(get_track_json "$id") || { echo "ERROR: Track not found: $id" >&2; return 1; }

  local new_json
  if command -v jq &>/dev/null; then
    new_json=$(echo "$json" | jq -c ". + {\"$field\": \"$value\"}")
  else
    # Check if field exists
    if echo "$json" | grep -q "\"$field\""; then
      new_json=$(echo "$json" | sed "s/\"$field\":\"[^\"]*\"/\"$field\":\"$value\"/")
    else
      # Add field before closing brace
      new_json=$(echo "$json" | sed "s/}$/,\"$field\":\"$value\"}/")
    fi
  fi

  # Also update the "updated" timestamp
  if [[ "$field" != "updated" ]]; then
    if command -v jq &>/dev/null; then
      new_json=$(echo "$new_json" | jq -c ". + {\"updated\": \"$(today_iso)\"}")
    else
      new_json=$(echo "$new_json" | sed "s/\"updated\":\"[^\"]*\"/\"updated\":\"$(today_iso)\"/")
    fi
  fi

  # Normalize field order for stable diffs
  new_json=$(normalize_json "$new_json")

  sedi "s|^${id}: .*|${id}: ${new_json}|" "$TRACKS_FILE"
}

get_track_deps() {
  # Returns dependency track IDs for a given track, one per line. Empty if none.
  local id="$1"
  [[ ! -f "$DEPS_FILE" ]] && return 0
  sed -n "/^${id}:/,/^[^ #]/p" "$DEPS_FILE" | grep "^  - " | sed 's/^  - //' || true
}

deps_satisfied() {
  # Returns 0 if all deps for track are completed (or no deps), 1 otherwise.
  local id="$1"
  local deps
  deps=$(get_track_deps "$id")
  [[ -z "$deps" ]] && return 0
  while read -r dep; do
    local dep_status
    dep_status=$(get_field "$dep" "status" 2>/dev/null || echo "unknown")
    [[ "$dep_status" != "completed" ]] && return 1
  done <<< "$deps"
  return 0
}

dep_summary() {
  # Returns a short string summarizing deps: "0/0", "2/3", etc. (satisfied/total)
  local id="$1"
  local deps
  deps=$(get_track_deps "$id")
  [[ -z "$deps" ]] && echo "-" && return 0
  local total=0 satisfied=0
  while read -r dep; do
    total=$((total + 1))
    local dep_status
    dep_status=$(get_field "$dep" "status" 2>/dev/null || echo "unknown")
    [[ "$dep_status" == "completed" ]] && satisfied=$((satisfied + 1))
  done <<< "$deps"
  if [[ "$satisfied" -eq "$total" ]]; then
    echo "${satisfied}/${total} ✓"
  else
    echo "${satisfied}/${total}"
  fi
}

# --- Commands ---

cmd_add() {
  local id="" title="" type="feature" status="pending" deps=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --title)  title="$2"; shift 2 ;;
      --type)   type="$2"; shift 2 ;;
      --status) status="$2"; shift 2 ;;
      --deps)   deps="$2"; shift 2 ;;
      -*)       echo "Unknown option: $1" >&2; return 1 ;;
      *)        id="$1"; shift ;;
    esac
  done

  if [[ -z "$id" ]]; then
    echo "Usage: kf-track add <track-id> --title \"...\" [--type feature|bug|chore|refactor] [--status pending] [--deps \"dep1,dep2\"]" >&2
    return 1
  fi
  if [[ -z "$title" ]]; then
    echo "ERROR: --title is required" >&2; return 1
  fi

  ensure_tracks_file

  if track_exists "$id"; then
    echo "ERROR: Track already exists: $id" >&2; return 1
  fi

  local created
  created=$(today_iso)
  local json

  # Build JSON with canonical field order
  if command -v jq &>/dev/null; then
    json=$(jq -nc \
      --arg title "$title" \
      --arg status "$status" \
      --arg type "$type" \
      --arg created "$created" \
      '{title:$title, status:$status, type:$type, created:$created, updated:$created}')
  else
    json="{\"title\":\"${title}\",\"status\":\"${status}\",\"type\":\"${type}\",\"created\":\"${created}\",\"updated\":\"${created}\"}"
  fi

  echo "${id}: ${json}" >> "$TRACKS_FILE"
  sort_tracks_file

  # Add to deps.yaml
  ensure_deps_file
  if [[ -n "$deps" ]]; then
    echo "" >> "$DEPS_FILE"
    echo "${id}:" >> "$DEPS_FILE"
    IFS=',' read -ra DEP_ARRAY <<< "$deps"
    for dep in "${DEP_ARRAY[@]}"; do
      echo "  - ${dep}" >> "$DEPS_FILE"
    done
  else
    echo "" >> "$DEPS_FILE"
    echo "${id}: []" >> "$DEPS_FILE"
  fi
  sort_deps_file

  echo "Added: ${id}"
}

cmd_update() {
  local id="" status=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --status) status="$2"; shift 2 ;;
      -*)       echo "Unknown option: $1" >&2; return 1 ;;
      *)        id="$1"; shift ;;
    esac
  done

  if [[ -z "$id" || -z "$status" ]]; then
    echo "Usage: kf-track update <track-id> --status <pending|in-progress|completed|archived>" >&2
    return 1
  fi

  ensure_tracks_file

  if ! track_exists "$id"; then
    echo "ERROR: Track not found: $id" >&2; return 1
  fi

  case "$status" in
    pending|in-progress|completed|archived) ;;
    *) echo "ERROR: Invalid status: $status (must be pending|in-progress|completed|archived)" >&2; return 1 ;;
  esac

  set_field "$id" "status" "$status"

  # If archived, add archived_at timestamp
  if [[ "$status" == "archived" ]]; then
    set_field "$id" "archived_at" "$(today_iso)"
  fi

  # If completed or archived, remove from deps.yaml and conflicts.yaml
  if [[ "$status" == "completed" || "$status" == "archived" ]]; then
    if [[ -f "$DEPS_FILE" ]]; then
      # Remove the track's own entry (key + any indented lines following it)
      sedi "/^${id}:/,/^[^ #]/{/^${id}:/d;/^  /d;}" "$DEPS_FILE"
      # Clean up any resulting blank lines
      sedi '/^$/N;/^\n$/d' "$DEPS_FILE"
    fi
    # Remove conflict pairs involving this track
    conflicts_clean_track "$id"
  fi

  echo "Updated: ${id} → ${status}"
}

cmd_set() {
  local id="" field="" value=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -*)
        field="${1#--}"
        value="$2"
        shift 2
        ;;
      *)
        if [[ -z "$id" ]]; then
          id="$1"; shift
        else
          echo "Unknown argument: $1" >&2; return 1
        fi
        ;;
    esac
  done

  if [[ -z "$id" || -z "$field" || -z "$value" ]]; then
    echo "Usage: kf-track set <track-id> --<field> <value>" >&2
    return 1
  fi

  ensure_tracks_file

  if ! track_exists "$id"; then
    echo "ERROR: Track not found: $id" >&2; return 1
  fi

  set_field "$id" "$field" "$value"
  echo "Set ${id}.${field} = ${value}"
}

cmd_get() {
  local id="" ref=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --ref)  ref="$2"; shift 2 ;;
      -*)     echo "Unknown option: $1" >&2; return 1 ;;
      *)      id="$1"; shift ;;
    esac
  done

  if [[ -z "$id" ]]; then
    echo "Usage: kf-track get <track-id> [--ref <branch|commit>]" >&2; return 1
  fi

  # If --ref is specified, override file paths with temp files from that ref
  if [[ -n "$ref" ]]; then
    local ref_tracks ref_deps
    ref_tracks=$(git show "${ref}:.agent/kf/tracks.yaml" 2>/dev/null) || {
      echo "ERROR: Cannot read tracks.yaml from ref '${ref}'" >&2; return 1
    }
    ref_deps=$(git show "${ref}:.agent/kf/tracks/deps.yaml" 2>/dev/null || true)
    local tmp_tracks tmp_deps
    tmp_tracks=$(mktemp)
    tmp_deps=$(mktemp)
    echo "$ref_tracks" > "$tmp_tracks"
    echo "$ref_deps" > "$tmp_deps"
    TRACKS_FILE="$tmp_tracks"
    DEPS_FILE="$tmp_deps"
    trap "rm -f '$tmp_tracks' '$tmp_deps'" RETURN
  fi

  local line
  line=$(get_track_line "$id") || { echo "ERROR: Track not found: $id" >&2; return 1; }

  local json
  json=$(echo "$line" | sed "s/^[^{]*//")

  if command -v jq &>/dev/null; then
    echo "Track: ${id}"
    echo "$json" | jq .
  else
    echo "Track: ${id}"
    echo "$json"
  fi

  # Show deps if any
  if [[ -f "$DEPS_FILE" ]]; then
    local deps
    deps=$(sed -n "/^${id}:/,/^[^ #]/p" "$DEPS_FILE" | grep "^  - " | sed 's/^  - //' || true)
    if [[ -n "$deps" ]]; then
      echo ""
      echo "Dependencies:"
      echo "$deps" | while read -r dep; do
        local dep_status
        dep_status=$(get_field "$dep" "status" 2>/dev/null || echo "unknown")
        local marker="[ ]"
        [[ "$dep_status" == "completed" ]] && marker="[x]"
        [[ "$dep_status" == "in-progress" ]] && marker="[~]"
        echo "  ${marker} ${dep}"
      done
    fi
  fi
}

cmd_list() {
  local filter_status="" filter_active="" filter_ready="" filter_unclaimed="" show_all=false format="table" ref=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --status)     filter_status="$2"; shift 2 ;;
      --active)     filter_active=true; shift ;;
      --ready)      filter_ready=true; shift ;;
      --unclaimed)  filter_unclaimed=true; filter_active=true; shift ;;
      --all)        show_all=true; shift ;;
      --json)       format="json"; shift ;;
      --ids)        format="ids"; shift ;;
      --ref)        ref="$2"; shift 2 ;;
      -*)           echo "Unknown option: $1" >&2; return 1 ;;
      *)            echo "Unknown argument: $1" >&2; return 1 ;;
    esac
  done

  # If --ref is specified, use git show to read from that ref
  if [[ -n "$ref" ]]; then
    local ref_tracks ref_deps
    ref_tracks=$(git show "${ref}:.agent/kf/tracks.yaml" 2>/dev/null) || {
      echo "ERROR: Cannot read tracks.yaml from ref '${ref}'" >&2; return 1
    }
    ref_deps=$(git show "${ref}:.agent/kf/tracks/deps.yaml" 2>/dev/null || true)
    # Create temp files for the ref data and redirect
    local tmp_tracks tmp_deps
    tmp_tracks=$(mktemp)
    tmp_deps=$(mktemp)
    echo "$ref_tracks" > "$tmp_tracks"
    echo "$ref_deps" > "$tmp_deps"
    # Override globals for this invocation
    TRACKS_FILE="$tmp_tracks"
    DEPS_FILE="$tmp_deps"
    trap "rm -f '$tmp_tracks' '$tmp_deps'" RETURN
  fi

  ensure_tracks_file

  # Default: --ready (active tracks with all deps satisfied)
  if [[ -z "$filter_status" && -z "$filter_active" && -z "$filter_ready" && "$show_all" != "true" ]]; then
    filter_ready=true
  fi

  # For --ready, start from active set then filter by deps
  if [[ "$filter_ready" == "true" ]]; then
    filter_active=true
  fi

  local lines
  if [[ -n "$filter_status" ]]; then
    lines=$(grep -v "^#" "$TRACKS_FILE" | grep -v "^$" | grep "\"status\":\"${filter_status}\"" || true)
  elif [[ "$filter_active" == "true" ]]; then
    lines=$(grep -v "^#" "$TRACKS_FILE" | grep -v "^$" | grep -v '"status":"completed"' | grep -v '"status":"archived"' || true)
  else
    lines=$(grep -v "^#" "$TRACKS_FILE" | grep -v "^$" || true)
  fi

  # Apply --ready filter: only tracks with all deps satisfied
  if [[ "$filter_ready" == "true" && -n "$lines" ]]; then
    local ready_lines=""
    while IFS= read -r line; do
      local id
      id=$(echo "$line" | sed 's/:.*//')
      if deps_satisfied "$id"; then
        if [[ -z "$ready_lines" ]]; then
          ready_lines="$line"
        else
          ready_lines="${ready_lines}
${line}"
        fi
      fi
    done <<< "$lines"
    lines="$ready_lines"
  fi

  # Build claimed tracks cache for enrichment
  local claimed_cache=""
  if [[ -n "$lines" ]]; then
    claimed_cache=$(get_claimed_tracks 2>/dev/null || true)
  fi

  # Apply --unclaimed filter: remove tracks that have implementation branches
  if [[ "$filter_unclaimed" == "true" && -n "$lines" && -n "$claimed_cache" ]]; then
    local unclaimed_lines=""
    while IFS= read -r line; do
      local id
      id=$(echo "$line" | sed 's/:.*//')
      if ! echo "$claimed_cache" | awk -F'\t' -v tid="$id" '$1 == tid {found=1; exit} END{exit !found}' 2>/dev/null; then
        if [[ -z "$unclaimed_lines" ]]; then
          unclaimed_lines="$line"
        else
          unclaimed_lines="${unclaimed_lines}
${line}"
        fi
      fi
    done <<< "$lines"
    lines="$unclaimed_lines"
  fi

  if [[ -z "$lines" ]]; then
    if [[ "$filter_unclaimed" == "true" ]]; then
      echo "(no unclaimed tracks — all active tracks are claimed by workers)"
    elif [[ "$filter_ready" == "true" ]]; then
      echo "(no ready tracks — all active tracks have unmet dependencies)"
    else
      echo "(no tracks match filter)"
    fi
    return 0
  fi

  # Sort: no-deps tracks first, then by unsatisfied dep count (ascending)
  local sorted_lines=""
  local no_deps_lines="" has_deps_lines=""
  while IFS= read -r line; do
    local id
    id=$(echo "$line" | sed 's/:.*//')
    local deps
    deps=$(get_track_deps "$id")
    if [[ -z "$deps" ]]; then
      no_deps_lines="${no_deps_lines}${line}
"
    else
      has_deps_lines="${has_deps_lines}${line}
"
    fi
  done <<< "$lines"
  # Combine: no-deps first, then has-deps
  sorted_lines="${no_deps_lines}${has_deps_lines}"
  # Remove trailing newline
  lines=$(echo "$sorted_lines" | sed '/^$/d')

  local count
  count=$(echo "$lines" | wc -l | tr -d ' ')

  case "$format" in
    ids)
      echo "$lines" | sed 's/:.*//'
      ;;
    json)
      echo "$lines" | while IFS= read -r line; do
        local id json
        id=$(echo "$line" | sed 's/:.*//')
        json=$(echo "$line" | sed "s/^[^{]*//")
        local deps_info
        deps_info=$(dep_summary "$id")
        if command -v jq &>/dev/null; then
          local dep_list
          dep_list=$(get_track_deps "$id" | jq -R . | jq -sc .)
          echo "$json" | jq -c ". + {\"id\": \"$id\", \"deps\": $dep_list, \"deps_summary\": \"$deps_info\"}"
        else
          echo "{\"id\":\"${id}\",\"deps_summary\":\"${deps_info}\",${json#\{}"
        fi
      done
      ;;
    table)
      # Print header
      printf "%-50s %-13s %-10s %-10s %s\n" "TRACK ID" "STATUS" "TYPE" "DEPS" "TITLE"
      printf "%-50s %-13s %-10s %-10s %s\n" "--------" "------" "----" "----" "-----"
      echo "$lines" | while IFS= read -r line; do
        local id json title status type deps_info
        id=$(echo "$line" | sed 's/:.*//')
        json=$(echo "$line" | sed "s/^[^{]*//")
        if command -v jq &>/dev/null; then
          title=$(echo "$json" | jq -r '.title // ""')
          status=$(echo "$json" | jq -r '.status // ""')
          type=$(echo "$json" | jq -r '.type // ""')
        else
          title=$(echo "$json" | grep -o '"title":"[^"]*"' | head -1 | sed 's/"title":"\(.*\)"/\1/')
          status=$(echo "$json" | grep -o '"status":"[^"]*"' | head -1 | sed 's/"status":"\(.*\)"/\1/')
          type=$(echo "$json" | grep -o '"type":"[^"]*"' | head -1 | sed 's/"type":"\(.*\)"/\1/')
        fi
        # Enrich status with claim detection
        if [[ "$status" == "pending" && -n "$claimed_cache" ]]; then
          local claimer
          claimer=$(echo "$claimed_cache" | awk -F'\t' -v tid="$id" '$1 == tid {print $2; exit}')
          if [[ -n "$claimer" ]]; then
            status="claimed"
          elif echo "$claimed_cache" | awk -F'\t' -v tid="$id" '$1 == tid {found=1; exit} END{exit !found}' 2>/dev/null; then
            status="claimed"
          fi
        fi
        deps_info=$(dep_summary "$id")
        # Truncate title if too long
        if [[ ${#title} -gt 50 ]]; then
          title="${title:0:47}..."
        fi
        printf "%-50s %-13s %-10s %-10s %s\n" "$id" "$status" "$type" "$deps_info" "$title"
      done
      echo ""
      if [[ "$filter_ready" == "true" ]]; then
        echo "${count} ready track(s)"
      else
        echo "${count} track(s)"
      fi
      ;;
  esac
}

cmd_deps() {
  local subcmd="${1:-}"; shift || true
  case "$subcmd" in
    add)
      local id="${1:-}" dep="${2:-}"
      if [[ -z "$id" || -z "$dep" ]]; then
        echo "Usage: kf-track deps add <track-id> <dependency-id>" >&2; return 1
      fi
      ensure_deps_file
      if grep -q "^${id}:" "$DEPS_FILE"; then
        # Track exists in deps — add dependency under it
        sedi "/^${id}:/{
          a\\
\\  - ${dep}
        }" "$DEPS_FILE"
      else
        echo "" >> "$DEPS_FILE"
        echo "${id}:" >> "$DEPS_FILE"
        echo "  - ${dep}" >> "$DEPS_FILE"
      fi
      sort_deps_file
      echo "Added dependency: ${id} → ${dep}"
      ;;
    remove)
      local id="${1:-}" dep="${2:-}"
      if [[ -z "$id" || -z "$dep" ]]; then
        echo "Usage: kf-track deps remove <track-id> <dependency-id>" >&2; return 1
      fi
      sedi "/^${id}:/,/^[^ #]/{/^  - ${dep}$/d;}" "$DEPS_FILE"
      echo "Removed dependency: ${id} → ${dep}"
      ;;
    list)
      local id="${1:-}"
      if [[ -z "$id" ]]; then
        echo "Usage: kf-track deps list <track-id>" >&2; return 1
      fi
      if [[ ! -f "$DEPS_FILE" ]]; then
        echo "(no deps.yaml found)"; return 0
      fi
      local deps
      deps=$(sed -n "/^${id}:/,/^[^ #]/p" "$DEPS_FILE" | grep "^  - " | sed 's/^  - //' || true)
      if [[ -z "$deps" ]]; then
        echo "(no dependencies)"
      else
        echo "$deps"
      fi
      ;;
    check)
      local id="${1:-}"
      if [[ -z "$id" ]]; then
        echo "Usage: kf-track deps check <track-id>" >&2; return 1
      fi
      if [[ ! -f "$DEPS_FILE" ]]; then
        echo "OK (no deps.yaml)"; return 0
      fi
      local deps
      deps=$(sed -n "/^${id}:/,/^[^ #]/p" "$DEPS_FILE" | grep "^  - " | sed 's/^  - //' || true)
      if [[ -z "$deps" ]]; then
        echo "OK (no dependencies)"; return 0
      fi
      local blocked=false
      echo "$deps" | while read -r dep; do
        local dep_status
        dep_status=$(get_field "$dep" "status" 2>/dev/null || echo "unknown")
        if [[ "$dep_status" == "completed" ]]; then
          echo "  [x] ${dep}"
        else
          echo "  [ ] ${dep} (${dep_status})"
          blocked=true
        fi
      done
      # Re-check for blocked (subshell issue)
      local any_blocked=false
      while read -r dep; do
        local dep_status
        dep_status=$(get_field "$dep" "status" 2>/dev/null || echo "unknown")
        if [[ "$dep_status" != "completed" ]]; then
          any_blocked=true
        fi
      done <<< "$deps"
      if [[ "$any_blocked" == "true" ]]; then
        echo "BLOCKED — not all dependencies completed"
        return 1
      else
        echo "OK — all dependencies satisfied"
        return 0
      fi
      ;;
    *)
      echo "Usage: kf-track deps <add|remove|list|check> <track-id> [dep-id]" >&2
      return 1
      ;;
  esac
}

# --- Conflict risk pairs ---
# conflicts.yaml stores pairs of tracks that may cause merge conflicts.
# Each pair is strictly ordered (lower ID first) so only one record per pair.
# Pairs are auto-cleaned when either track completes/archives.

ensure_conflicts_file() {
  if [[ ! -f "$CONFLICTS_FILE" ]]; then
    mkdir -p "$(dirname "$CONFLICTS_FILE")"
    cat > "$CONFLICTS_FILE" <<HEADER
# Track Conflict Risk Pairs
#
# PROTOCOL:
#   Each line: <id-a>/<id-b>: {"risk":"high|medium|low","note":"...","added":"..."}
#   Pair key is strictly ordered: lower ID / higher ID (only one record per pair).
#
# RULES:
#   - Architect adds pairs when generating tracks that may conflict.
#   - Pairs auto-cleaned when either track completes or is archived.
#   - Only active (pending/in-progress) tracks should have pairs.
#
# TOOL: Use \`kf-track conflicts\` to manage entries. Do not edit by hand.
#
HEADER
  fi
}

# Build the canonical pair key (lower/higher alphabetical order)
conflict_pair_key() {
  local a="$1" b="$2"
  if [[ "$a" < "$b" ]]; then
    echo "${a}/${b}"
  else
    echo "${b}/${a}"
  fi
}

sort_conflicts_file() {
  [[ ! -f "$CONFLICTS_FILE" ]] && return
  local header data
  header=$(grep "^#" "$CONFLICTS_FILE" || true)
  data=$(grep -v "^#" "$CONFLICTS_FILE" | grep -v "^$" | LC_ALL=C sort || true)
  {
    echo "$header"
    [[ -n "$data" ]] && echo "" && echo "$data"
  } > "${CONFLICTS_FILE}.tmp"
  mv "${CONFLICTS_FILE}.tmp" "$CONFLICTS_FILE"
}

# Remove all conflict pairs involving a specific track ID
conflicts_clean_track() {
  local id="$1"
  [[ ! -f "$CONFLICTS_FILE" ]] && return
  # Remove lines where the track ID appears as either half of the pair key.
  # Pair format: <id-a>/<id-b>: {json}
  # Match id at start of line (before /) or after /
  sedi "/^${id}\//d" "$CONFLICTS_FILE"
  sedi "/\/${id}:/d" "$CONFLICTS_FILE"
}

cmd_conflicts() {
  local subcmd="${1:-}"; shift || true
  case "$subcmd" in
    add)
      local id_a="${1:-}" id_b="${2:-}" risk="${3:-medium}" note="${4:-}"
      if [[ -z "$id_a" || -z "$id_b" ]]; then
        echo "Usage: kf-track conflicts add <track-a> <track-b> [risk] [note]" >&2
        echo "  risk: high, medium, low (default: medium)" >&2
        return 1
      fi
      if [[ "$id_a" == "$id_b" ]]; then
        echo "ERROR: Cannot create conflict pair with itself" >&2; return 1
      fi
      ensure_conflicts_file
      local pair_key
      pair_key=$(conflict_pair_key "$id_a" "$id_b")
      # Remove existing record for this pair (update semantics)
      sedi "/^${pair_key//\//\\/}:/d" "$CONFLICTS_FILE"
      # Build JSON
      local json
      if command -v jq &>/dev/null; then
        json=$(jq -nc --arg r "$risk" --arg n "$note" --arg d "$(today_iso)" \
          '{risk: $r, note: $n, added: $d}')
      else
        json="{\"risk\":\"${risk}\",\"note\":\"${note}\",\"added\":\"$(today_iso)\"}"
      fi
      echo "${pair_key}: ${json}" >> "$CONFLICTS_FILE"
      sort_conflicts_file
      echo "Added conflict pair: ${pair_key} (risk: ${risk})"
      ;;
    remove)
      local id_a="${1:-}" id_b="${2:-}"
      if [[ -z "$id_a" || -z "$id_b" ]]; then
        echo "Usage: kf-track conflicts remove <track-a> <track-b>" >&2; return 1
      fi
      local pair_key
      pair_key=$(conflict_pair_key "$id_a" "$id_b")
      sedi "/^${pair_key//\//\\/}:/d" "$CONFLICTS_FILE"
      echo "Removed conflict pair: ${pair_key}"
      ;;
    list)
      local filter_id="${1:-}"
      if [[ ! -f "$CONFLICTS_FILE" ]]; then
        echo "(no conflicts.yaml)"; return 0
      fi
      local data
      if [[ -n "$filter_id" ]]; then
        data=$(grep -v "^#" "$CONFLICTS_FILE" | grep -v "^$" | grep "$filter_id" || true)
      else
        data=$(grep -v "^#" "$CONFLICTS_FILE" | grep -v "^$" || true)
      fi
      if [[ -z "$data" ]]; then
        echo "(no conflict pairs${filter_id:+ for $filter_id})"
      else
        echo "$data" | while IFS= read -r line; do
          local pair_key json risk
          pair_key="${line%%:*}"
          json="${line#*: }"
          risk=$(echo "$json" | jq -r '.risk // "?"' 2>/dev/null || echo "?")
          local note
          note=$(echo "$json" | jq -r '.note // ""' 2>/dev/null || echo "")
          printf "  %-60s  %s" "$pair_key" "risk=${risk}"
          [[ -n "$note" ]] && printf "  %s" "$note"
          echo
        done
      fi
      ;;
    clean)
      # Remove pairs involving completed/archived tracks
      if [[ ! -f "$CONFLICTS_FILE" ]]; then
        echo "(no conflicts.yaml)"; return 0
      fi
      local removed=0
      local pairs
      pairs=$(grep -v "^#" "$CONFLICTS_FILE" | grep -v "^$" || true)
      while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        local pair_key="${line%%:*}"
        local id_a="${pair_key%%/*}"
        local id_b="${pair_key##*/}"
        local status_a status_b
        status_a=$(get_field "$id_a" "status" 2>/dev/null || echo "unknown")
        status_b=$(get_field "$id_b" "status" 2>/dev/null || echo "unknown")
        if [[ "$status_a" == "completed" || "$status_a" == "archived" || \
              "$status_b" == "completed" || "$status_b" == "archived" || \
              "$status_a" == "unknown" || "$status_b" == "unknown" ]]; then
          sedi "/^${pair_key//\//\\/}:/d" "$CONFLICTS_FILE"
          echo "  Removed: ${pair_key} (${id_a}=${status_a}, ${id_b}=${status_b})"
          ((removed++)) || true
        fi
      done <<< "$pairs"
      echo "Cleaned ${removed} stale conflict pair(s)"
      ;;
    *)
      echo "Usage: kf-track conflicts <add|remove|list|clean> [args]" >&2
      echo "  add <track-a> <track-b> [risk] [note]  Add/update conflict pair" >&2
      echo "  remove <track-a> <track-b>              Remove conflict pair" >&2
      echo "  list [track-id]                         List pairs (optionally filtered)" >&2
      echo "  clean                                   Remove pairs for completed tracks" >&2
      return 1
      ;;
  esac
}

cmd_archive() {
  local id="${1:-}" reason="${2:-completed}"
  if [[ -z "$id" ]]; then
    echo "Usage: kf-track archive <track-id> [reason]" >&2; return 1
  fi

  if ! track_exists "$id"; then
    echo "ERROR: Track not found: $id" >&2; return 1
  fi

  set_field "$id" "status" "archived"
  set_field "$id" "archived_at" "$(today_iso)"
  set_field "$id" "archive_reason" "$reason"

  # Remove from deps.yaml
  if [[ -f "$DEPS_FILE" ]]; then
    sedi "/^${id}:/,/^[^ #]/{/^${id}:/d;/^  /d;}" "$DEPS_FILE"
  fi

  # Remove conflict pairs involving this track
  conflicts_clean_track "$id"

  echo "Archived: ${id} (reason: ${reason})"
}

# --- Config: compactions ---
COMPACTIONS_FILE="${KF_DIR}/compactions.yaml"
TRACKS_DIR="${KF_DIR}/tracks"
ARCHIVE_DIR="${TRACKS_DIR}/_archive"

ensure_compactions_file() {
  if [[ ! -f "$COMPACTIONS_FILE" ]]; then
    cat > "$COMPACTIONS_FILE" <<'HEADER'
# Kiloforge Compaction Registry
#
# FORMAT: <commit-hash>: {"date":"...","completed":N,"archived":N,"track_ids":["..."],"first_created":"...","last_created":"..."}
# ORDER:  Lines sorted by date (newest first) — most recent compaction at top of data section.
# TOOL:   Use `kf-track compact` to manage. Do not edit by hand.
#
# RECOVERY:
#   git show <commit>:.agent/kf/tracks.yaml              — full track registry at that point
#   git show <commit>:.agent/kf/tracks/<id>/spec.md      — specific track files
#   git ls-tree <commit> .agent/kf/tracks/                — list all track directories
#
HEADER
  fi
}

cmd_compact() {
  local subcmd="${1:-run}"; shift 2>/dev/null || true
  case "$subcmd" in
    run)
      _compact_run "$@"
      ;;
    list)
      _compact_list "$@"
      ;;
    recover)
      _compact_recover "$@"
      ;;
    import)
      _compact_import "$@"
      ;;
    *)
      echo "Usage: kf-track compact <run|list|recover [hash]|import [hash] [--source ...]>" >&2
      return 1
      ;;
  esac
}

_compact_run() {
  local dry_run=false
  [[ "${1:-}" == "--dry-run" ]] && dry_run=true

  ensure_tracks_file
  ensure_compactions_file

  # Collect compactable tracks from both sources
  local compactable_ids=()
  local completed_ids=()
  local archived_dir_ids=()

  # Source 1: archived track directories
  if [[ -d "$ARCHIVE_DIR" ]]; then
    for dir in "$ARCHIVE_DIR"/*/; do
      [[ -d "$dir" ]] || continue
      local dirname
      dirname=$(basename "$dir")
      archived_dir_ids+=("$dirname")
      compactable_ids+=("$dirname")
    done
  fi

  # Source 2: completed tracks with directories
  local completed_lines
  completed_lines=$(grep -v "^#" "$TRACKS_FILE" | grep -v "^$" | grep '"status":"completed"' || true)
  if [[ -n "$completed_lines" ]]; then
    while IFS= read -r line; do
      local tid
      tid=$(echo "$line" | sed 's/:.*//')
      if [[ -d "${TRACKS_DIR}/${tid}" ]]; then
        completed_ids+=("$tid")
        # Avoid duplicates (track could be in both)
        local already=false
        for existing in "${compactable_ids[@]:-}"; do
          [[ "$existing" == "$tid" ]] && already=true
        done
        [[ "$already" == "false" ]] && compactable_ids+=("$tid")
      fi
    done <<< "$completed_lines"
  fi

  if [[ ${#compactable_ids[@]} -eq 0 ]]; then
    echo "Nothing to compact — no archived directories or completed track directories found."
    return 0
  fi

  # Gather metadata
  local total=${#compactable_ids[@]}
  local completed_count=${#completed_ids[@]}
  local archived_count=${#archived_dir_ids[@]}
  local first_created="" last_created=""

  for tid in "${compactable_ids[@]}"; do
    local created
    created=$(get_field "$tid" "created" 2>/dev/null || echo "")
    if [[ -n "$created" && "$created" != "null" ]]; then
      if [[ -z "$first_created" || "$created" < "$first_created" ]]; then
        first_created="$created"
      fi
      if [[ -z "$last_created" || "$created" > "$last_created" ]]; then
        last_created="$created"
      fi
    fi
  done

  local commit_hash
  commit_hash=$(git rev-parse HEAD 2>/dev/null || echo "unknown")
  local compact_date
  compact_date=$(today_iso)

  echo "Compaction summary:"
  echo "  Total tracks to compact: ${total}"
  echo "  From _archive/:          ${archived_count}"
  echo "  Completed (with dirs):   ${completed_count}"
  echo "  Date range:              ${first_created:-unknown} — ${last_created:-unknown}"
  echo "  Recovery commit:         ${commit_hash}"
  echo ""

  if [[ "$dry_run" == "true" ]]; then
    echo "(dry run — no changes made)"
    echo ""
    echo "Tracks that would be compacted:"
    for tid in "${compactable_ids[@]}"; do
      echo "  ${tid}"
    done
    return 0
  fi

  # Build JSON for track_ids array
  local ids_json="["
  local first=true
  for tid in "${compactable_ids[@]}"; do
    if [[ "$first" == "true" ]]; then
      ids_json+="\"${tid}\""
      first=false
    else
      ids_json+=",\"${tid}\""
    fi
  done
  ids_json+="]"

  # Build compaction record
  local record
  if command -v jq &>/dev/null; then
    record=$(jq -nc \
      --arg date "$compact_date" \
      --argjson completed "$completed_count" \
      --argjson archived "$archived_count" \
      --argjson track_ids "$ids_json" \
      --arg first_created "${first_created:-}" \
      --arg last_created "${last_created:-}" \
      '{date:$date, completed:$completed, archived:$archived, track_ids:$track_ids, first_created:$first_created, last_created:$last_created}')
  else
    record="{\"date\":\"${compact_date}\",\"completed\":${completed_count},\"archived\":${archived_count},\"track_ids\":${ids_json},\"first_created\":\"${first_created:-}\",\"last_created\":\"${last_created:-}\"}"
  fi

  # Delete directories
  for tid in "${archived_dir_ids[@]}"; do
    rm -rf "${ARCHIVE_DIR}/${tid}"
  done
  # Remove _archive dir if empty
  rmdir "$ARCHIVE_DIR" 2>/dev/null || true

  for tid in "${completed_ids[@]}"; do
    rm -rf "${TRACKS_DIR}/${tid}"
  done

  # Archive completed tracks in tracks.yaml
  for tid in "${completed_ids[@]}"; do
    set_field "$tid" "status" "archived"
    set_field "$tid" "archived_at" "$compact_date"
    set_field "$tid" "archive_reason" "compacted — recover from ${commit_hash}"
  done

  # Record compaction
  echo "${commit_hash}: ${record}" >> "$COMPACTIONS_FILE"

  # Commit
  git add "${TRACKS_DIR}" "${TRACKS_FILE}" "${COMPACTIONS_FILE}" 2>/dev/null
  git commit -m "chore: compact archive (${completed_count} completed, ${archived_count} archived — recover from ${commit_hash})" 2>/dev/null || true

  echo "Compaction complete."
  echo "  Removed ${total} track directories"
  echo "  Recovery: git show ${commit_hash}:.agent/kf/tracks/<trackId>/spec.md"
}

_compact_list() {
  local format="${1:---table}"
  ensure_compactions_file

  local lines
  lines=$(grep -v "^#" "$COMPACTIONS_FILE" | grep -v "^$" || true)

  if [[ -z "$lines" ]]; then
    echo "(no compaction records)"
    return 0
  fi

  case "$format" in
    --json)
      echo "$lines" | while IFS= read -r line; do
        local hash json
        hash=$(echo "$line" | sed 's/:.*//')
        json=$(echo "$line" | sed 's/^[^{]*//')
        if command -v jq &>/dev/null; then
          echo "$json" | jq -c ". + {\"commit\": \"$hash\"}"
        else
          echo "{\"commit\":\"${hash}\",${json#\{}"
        fi
      done
      ;;
    *)
      printf "%-12s %-12s %-12s %-10s %-10s %-12s %-12s\n" "COMMIT" "DATE" "SOURCE" "COMPLETED" "ARCHIVED" "FIRST" "LAST"
      printf "%-12s %-12s %-12s %-10s %-10s %-12s %-12s\n" "------" "----" "------" "---------" "--------" "-----" "----"
      echo "$lines" | while IFS= read -r line; do
        local hash json date source completed archived first_created last_created
        hash=$(echo "$line" | sed 's/:.*//')
        json=$(echo "$line" | sed 's/^[^{]*//')
        if command -v jq &>/dev/null; then
          date=$(echo "$json" | jq -r '.date // ""')
          source=$(echo "$json" | jq -r '.source // "kf"')
          completed=$(echo "$json" | jq -r '.completed // 0')
          archived=$(echo "$json" | jq -r '.archived // 0')
          first_created=$(echo "$json" | jq -r '.first_created // ""')
          last_created=$(echo "$json" | jq -r '.last_created // ""')
        else
          date=$(echo "$json" | grep -o '"date":"[^"]*"' | head -1 | sed 's/"date":"\(.*\)"/\1/')
          source=$(echo "$json" | grep -o '"source":"[^"]*"' | head -1 | sed 's/"source":"\(.*\)"/\1/')
          [[ -z "$source" ]] && source="kf"
          completed=$(echo "$json" | grep -o '"completed":[0-9]*' | head -1 | sed 's/"completed"://')
          archived=$(echo "$json" | grep -o '"archived":[0-9]*' | head -1 | sed 's/"archived"://')
          first_created=$(echo "$json" | grep -o '"first_created":"[^"]*"' | head -1 | sed 's/"first_created":"\(.*\)"/\1/')
          last_created=$(echo "$json" | grep -o '"last_created":"[^"]*"' | head -1 | sed 's/"last_created":"\(.*\)"/\1/')
        fi
        printf "%-12s %-12s %-12s %-10s %-10s %-12s %-12s\n" "${hash:0:10}" "$date" "$source" "$completed" "$archived" "$first_created" "$last_created"
      done
      echo ""
      echo "$(echo "$lines" | wc -l | tr -d ' ') compaction(s)"
      ;;
  esac
}

_compact_recover() {
  local hash="${1:-}"
  if [[ -z "$hash" ]]; then
    echo "Usage: kf-track compact recover <commit-hash>" >&2
    echo "" >&2
    echo "Shows recovery commands for a compaction point." >&2
    echo "Use 'kf-track compact list' to see available compaction points." >&2
    return 1
  fi

  ensure_compactions_file

  local line
  line=$(grep "^${hash}" "$COMPACTIONS_FILE" 2>/dev/null || true)

  if [[ -z "$line" ]]; then
    # Try partial hash match
    line=$(grep "^${hash}" "$COMPACTIONS_FILE" 2>/dev/null | head -1 || true)
  fi

  if [[ -z "$line" ]]; then
    echo "ERROR: No compaction record found for commit ${hash}" >&2
    echo "Use 'kf-track compact list' to see available compaction points." >&2
    return 1
  fi

  local full_hash json
  full_hash=$(echo "$line" | sed 's/:.*//')
  json=$(echo "$line" | sed 's/^[^{]*//')

  local source="kf"
  if command -v jq &>/dev/null; then
    source=$(echo "$json" | jq -r '.source // "kf"')
  fi

  echo "Recovery commands for compaction ${full_hash:0:10} (source: ${source}):"
  echo ""

  if [[ "$source" == "conductor" ]]; then
    echo "# This is a conductor-era compaction. Use .agent/conductor/ paths:"
    echo ""
    echo "# Full track registry (markdown table):"
    echo "git show ${full_hash}:.agent/conductor/tracks.md"
    echo ""
    echo "# List archived track directories:"
    echo "git ls-tree ${full_hash} .agent/conductor/tracks/_archive/"
    echo ""
    echo "# List all track directories:"
    echo "git ls-tree ${full_hash} .agent/conductor/tracks/"
    echo ""
    echo "# Recover a specific track's spec:"
    echo "git show ${full_hash}:.agent/conductor/tracks/<trackId>/spec.md"
    echo "git show ${full_hash}:.agent/conductor/tracks/_archive/<trackId>/spec.md"
  elif command -v jq &>/dev/null; then
    local track_ids
    track_ids=$(echo "$json" | jq -r '.track_ids[]' 2>/dev/null || true)
    echo "# List all track directories at that point:"
    echo "git ls-tree ${full_hash} .agent/kf/tracks/"
    echo ""
    echo "# Full track registry at that point:"
    echo "git show ${full_hash}:.agent/kf/tracks.yaml"
    echo ""
    if [[ -n "$track_ids" ]]; then
      echo "# Recover specific tracks:"
      echo "$track_ids" | while read -r tid; do
        [[ -n "$tid" ]] && echo "git show ${full_hash}:.agent/kf/tracks/${tid}/spec.md"
      done
    fi
  else
    echo "git ls-tree ${full_hash} .agent/kf/tracks/"
    echo "git show ${full_hash}:.agent/kf/tracks.yaml"
  fi
}

_compact_import() {
  # Import a legacy compaction record (e.g., from conductor migration).
  # Usage: kf-track compact import <commit-hash> --source conductor --note "..."
  local hash="" source="conductor" note="" track_count=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --source) source="$2"; shift 2 ;;
      --note)   note="$2"; shift 2 ;;
      --count)  track_count="$2"; shift 2 ;;
      -*)       echo "Unknown option: $1" >&2; return 1 ;;
      *)        hash="$1"; shift ;;
    esac
  done

  if [[ -z "$hash" ]]; then
    echo "Usage: kf-track compact import <commit-hash> [--source conductor] [--note \"...\"] [--count N]" >&2
    return 1
  fi

  ensure_compactions_file

  # Check if already recorded
  if grep -q "^${hash}" "$COMPACTIONS_FILE" 2>/dev/null; then
    echo "ERROR: Compaction record already exists for ${hash}" >&2
    return 1
  fi

  local compact_date
  compact_date=$(today_iso)

  local record
  if command -v jq &>/dev/null; then
    record=$(jq -nc \
      --arg date "$compact_date" \
      --arg source "$source" \
      --arg note "$note" \
      --argjson count "$track_count" \
      '{date:$date, source:$source, completed:$count, archived:0, track_ids:[], note:$note}')
  else
    record="{\"date\":\"${compact_date}\",\"source\":\"${source}\",\"completed\":${track_count},\"archived\":0,\"track_ids\":[],\"note\":\"${note}\"}"
  fi

  echo "${hash}: ${record}" >> "$COMPACTIONS_FILE"
  echo "Imported compaction record: ${hash:0:10} (source: ${source})"
}

# --- Index command ---

QUICK_LINKS_FILE="${KF_DIR}/quick-links.md"

ensure_quick_links_file() {
  if [[ ! -f "$QUICK_LINKS_FILE" ]]; then
    cat > "$QUICK_LINKS_FILE" <<'QL'
# Quick Links
#
# Navigation links to key project files. Managed by `kf-track quick-links`.
#
# FORMAT: - [Label](./relative/path.md)

- [Product Definition](./product.md)
- [Tech Stack](./tech-stack.md)
- [Tracks Registry](./tracks.yaml)
QL
  fi
}

cmd_quick_links() {
  local subcmd="${1:-show}"; shift 2>/dev/null || true

  case "$subcmd" in
    show)
      local ref=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --ref)  ref="$2"; shift 2 ;;
          *)      echo "Unknown argument: $1" >&2; return 1 ;;
        esac
      done
      if [[ -n "$ref" ]]; then
        local content
        content=$(git show "${ref}:.agent/kf/quick-links.md" 2>/dev/null) || {
          echo "ERROR: Cannot read quick-links.md from ref '${ref}'" >&2; return 1
        }
        echo "$content" | grep -v "^#" | grep -v "^$" || true
      else
        ensure_quick_links_file
        grep -v "^#" "$QUICK_LINKS_FILE" | grep -v "^$" || true
      fi
      ;;
    add)
      local label="${1:-}" path="${2:-}"
      if [[ -z "$label" || -z "$path" ]]; then
        echo "Usage: kf-track quick-links add <label> <path>" >&2
        return 1
      fi
      ensure_quick_links_file
      # Check if label already exists
      if grep -q "\[${label}\]" "$QUICK_LINKS_FILE" 2>/dev/null; then
        echo "Quick link '${label}' already exists. Remove first to update." >&2
        return 1
      fi
      echo "- [${label}](${path})" >> "$QUICK_LINKS_FILE"
      echo "Added quick link: ${label} → ${path}"
      ;;
    remove)
      local label="${1:-}"
      if [[ -z "$label" ]]; then
        echo "Usage: kf-track quick-links remove <label>" >&2
        return 1
      fi
      if [[ ! -f "$QUICK_LINKS_FILE" ]]; then
        echo "No quick-links.md file found." >&2
        return 1
      fi
      if ! grep -q "\[${label}\]" "$QUICK_LINKS_FILE" 2>/dev/null; then
        echo "Quick link '${label}' not found." >&2
        return 1
      fi
      sedi "/\[${label}\]/d" "$QUICK_LINKS_FILE"
      echo "Removed quick link: ${label}"
      ;;
    *)
      echo "Usage: kf-track quick-links [show|add <label> <path>|remove <label>]" >&2
      return 1
      ;;
  esac
}

cmd_index() {
  local ref=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --ref)    ref="$2"; shift 2 ;;
      -*)       echo "Unknown option: $1" >&2; return 1 ;;
      *)        echo "Unknown argument: $1" >&2; return 1 ;;
    esac
  done

  local tracks_content quick_links_content
  if [[ -n "$ref" ]]; then
    tracks_content=$(git show "${ref}:.agent/kf/tracks.yaml" 2>/dev/null) || {
      echo "ERROR: Cannot read tracks.yaml from ref '${ref}'" >&2; return 1
    }
    quick_links_content=$(git show "${ref}:.agent/kf/quick-links.md" 2>/dev/null || true)
  else
    ensure_tracks_file
    tracks_content=$(cat "$TRACKS_FILE")
    ensure_quick_links_file
    quick_links_content=$(cat "$QUICK_LINKS_FILE")
  fi

  # Build the index output
  local output=""
  output+="# Kiloforge Project Index"$'\n'
  output+=""$'\n'

  # Quick links section
  if [[ -n "$quick_links_content" ]]; then
    output+="## Quick Links"$'\n'
    output+=""$'\n'
    output+="$(echo "$quick_links_content" | grep -v "^#" | grep -v "^$" || true)"$'\n'
    output+=""$'\n'
  fi

  # Count tracks by status
  local pending=0 in_progress=0 completed=0 archived=0 total=0
  while IFS= read -r line; do
    [[ -z "$line" || "$line" == \#* ]] && continue
    total=$((total + 1))
    case "$line" in
      *'"status":"pending"'*)      pending=$((pending + 1)) ;;
      *'"status":"in-progress"'*)  in_progress=$((in_progress + 1)) ;;
      *'"status":"completed"'*)    completed=$((completed + 1)) ;;
      *'"status":"archived"'*)     archived=$((archived + 1)) ;;
    esac
  done <<< "$tracks_content"

  output+="## Summary"$'\n'
  output+=""$'\n'
  output+="| Status | Count |"$'\n'
  output+="|--------|-------|"$'\n'
  output+="| Pending | ${pending} |"$'\n'
  output+="| In Progress | ${in_progress} |"$'\n'
  output+="| Completed | ${completed} |"$'\n'
  output+="| Archived | ${archived} |"$'\n'
  output+="| **Total** | **${total}** |"$'\n'
  output+=""$'\n'

  # In-progress tracks
  if [[ "$in_progress" -gt 0 ]]; then
    output+="## In Progress"$'\n'
    output+=""$'\n'
    while IFS= read -r line; do
      [[ -z "$line" || "$line" == \#* ]] && continue
      [[ "$line" != *'"status":"in-progress"'* ]] && continue
      local id title
      id=$(echo "$line" | sed 's/:.*//')
      if command -v jq &>/dev/null; then
        title=$(echo "$line" | sed "s/^[^{]*//" | jq -r '.title // ""')
      else
        title=$(echo "$line" | grep -o '"title":"[^"]*"' | head -1 | sed 's/"title":"\(.*\)"/\1/')
      fi
      output+="- **${id}** — ${title}"$'\n'
    done <<< "$tracks_content"
    output+=""$'\n'
  fi

  # Pending tracks
  if [[ "$pending" -gt 0 ]]; then
    output+="## Pending"$'\n'
    output+=""$'\n'
    while IFS= read -r line; do
      [[ -z "$line" || "$line" == \#* ]] && continue
      [[ "$line" != *'"status":"pending"'* ]] && continue
      local id title
      id=$(echo "$line" | sed 's/:.*//')
      if command -v jq &>/dev/null; then
        title=$(echo "$line" | sed "s/^[^{]*//" | jq -r '.title // ""')
      else
        title=$(echo "$line" | grep -o '"title":"[^"]*"' | head -1 | sed 's/"title":"\(.*\)"/\1/')
      fi
      output+="- **${id}** — ${title}"$'\n'
    done <<< "$tracks_content"
    output+=""$'\n'
  fi

  echo "$output"
}

cmd_content() {
  local cmd="$1"; shift
  if ! command -v python3 &>/dev/null; then
    echo "ERROR: python3 is required for 'kf-track $cmd' but was not found." >&2
    echo "" >&2
    echo "Install Python 3:" >&2
    echo "  macOS:   brew install python3" >&2
    echo "  Ubuntu:  sudo apt install python3" >&2
    echo "  Windows: https://www.python.org/downloads/" >&2
    exit 1
  fi
  # Handle --ref for read-only content commands: extract track.yaml from git ref
  local ref="" content_args=()
  for arg in "$@"; do
    if [[ "$arg" == "--ref" ]]; then
      ref="__next__"
      continue
    fi
    if [[ "$ref" == "__next__" ]]; then
      ref="$arg"
      continue
    fi
    content_args+=("$arg")
  done
  if [[ -n "$ref" && "$ref" != "__next__" ]]; then
    # Read-only commands only
    case "$cmd" in
      show|spec|plan|progress)
        local track_id="${content_args[0]:-}"
        if [[ -z "$track_id" ]]; then
          echo "ERROR: track ID required" >&2; exit 1
        fi
        local ref_yaml
        ref_yaml=$(git show "${ref}:.agent/kf/tracks/${track_id}/track.yaml" 2>/dev/null) || {
          echo "ERROR: Cannot read track.yaml for '${track_id}' from ref '${ref}'" >&2; exit 1
        }
        local tmp_dir
        tmp_dir=$(mktemp -d)
        mkdir -p "${tmp_dir}/tracks/${track_id}"
        echo "$ref_yaml" > "${tmp_dir}/tracks/${track_id}/track.yaml"
        KF_DIR="$tmp_dir" "${SCRIPT_DIR}/kf-track-content" "$cmd" "${content_args[@]}"
        rm -rf "$tmp_dir"
        ;;
      *)
        echo "ERROR: --ref is only supported for read-only commands (show, spec, plan, progress)" >&2
        exit 1
        ;;
    esac
  else
    exec "${SCRIPT_DIR}/kf-track-content" "$cmd" "$@"
  fi
}

# --- Status command ---
cmd_status() {
  local ref=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --ref)    ref="$2"; shift 2 ;;
      -*)       echo "Unknown option: $1" >&2; return 1 ;;
      *)        echo "Unknown argument: $1" >&2; return 1 ;;
    esac
  done

  # Helper: read a file from ref or local
  _read_file() {
    local path="$1"
    if [[ -n "$ref" ]]; then
      git show "${ref}:${path}" 2>/dev/null || true
    else
      cat "${KF_DIR}/../../${path}" 2>/dev/null || cat "${KF_DIR}/${path#.agent/kf/}" 2>/dev/null || true
    fi
  }

  # Helper: read kf-relative file
  _read_kf() {
    local path="$1"
    if [[ -n "$ref" ]]; then
      git show "${ref}:.agent/kf/${path}" 2>/dev/null || true
    else
      cat "${KF_DIR}/${path}" 2>/dev/null || true
    fi
  }

  # --- Project name ---
  local product_content
  product_content=$(_read_kf "product.md")
  local project_name="Unknown"
  if [[ -n "$product_content" ]]; then
    # Try to extract project name from "## Project Name" section or first heading
    project_name=$(echo "$product_content" | awk '/^## Project Name/{getline; while(/^$/){getline}; print; exit}')
    if [[ -z "$project_name" ]]; then
      project_name=$(echo "$product_content" | grep -m1 "^# " | sed 's/^# //')
    fi
  fi

  # --- Tracks data ---
  local tracks_content
  tracks_content=$(_read_kf "tracks.yaml")
  if [[ -z "$tracks_content" ]]; then
    echo "ERROR: No tracks.yaml found. Run /kf-setup first." >&2
    return 1
  fi

  # Count by status
  local pending=0 in_progress=0 completed=0 archived=0 total=0
  while IFS= read -r line; do
    [[ -z "$line" || "$line" == \#* ]] && continue
    total=$((total + 1))
    case "$line" in
      *'"status":"pending"'*)      pending=$((pending + 1)) ;;
      *'"status":"in-progress"'*)  in_progress=$((in_progress + 1)) ;;
      *'"status":"completed"'*)    completed=$((completed + 1)) ;;
      *'"status":"archived"'*)     archived=$((archived + 1)) ;;
    esac
  done <<< "$tracks_content"

  # --- Task progress for active tracks ---
  # Build arrays for pending and in-progress tracks
  local -a active_ids=() active_titles=() active_types=() active_statuses=()
  local -a active_task_done=() active_task_total=() active_phase_done=() active_phase_total=()
  local -a active_next_task=()

  while IFS= read -r line; do
    [[ -z "$line" || "$line" == \#* ]] && continue
    [[ "$line" != *'"status":"pending"'* && "$line" != *'"status":"in-progress"'* ]] && continue

    local tid ttitle ttype tstatus
    tid=$(echo "$line" | sed 's/:.*//')
    if command -v jq &>/dev/null; then
      local json
      json=$(echo "$line" | sed "s/^[^{]*//")
      ttitle=$(echo "$json" | jq -r '.title // ""')
      ttype=$(echo "$json" | jq -r '.type // ""')
      tstatus=$(echo "$json" | jq -r '.status // ""')
    else
      ttitle=$(echo "$line" | grep -o '"title":"[^"]*"' | head -1 | sed 's/"title":"\(.*\)"/\1/')
      ttype=$(echo "$line" | grep -o '"type":"[^"]*"' | head -1 | sed 's/"type":"\(.*\)"/\1/')
      tstatus=$(echo "$line" | grep -o '"status":"[^"]*"' | head -1 | sed 's/"status":"\(.*\)"/\1/')
    fi

    # Get task progress from track.yaml plan
    local track_yaml=""
    if [[ -n "$ref" ]]; then
      track_yaml=$(git show "${ref}:.agent/kf/tracks/${tid}/track.yaml" 2>/dev/null || true)
    else
      local track_file="${KF_DIR}/tracks/${tid}/track.yaml"
      [[ -f "$track_file" ]] && track_yaml=$(cat "$track_file")
    fi

    local tdone=0 ttotal=0 pdone=0 ptotal=0 next_task=""
    if [[ -n "$track_yaml" ]]; then
      # Count tasks from plan section
      local in_plan=false in_tasks=false phase_has_pending=false
      ptotal=0
      while IFS= read -r pline; do
        if [[ "$pline" == "plan:" ]]; then
          in_plan=true; continue
        fi
        [[ "$in_plan" != true ]] && continue
        # Stop at next top-level key
        if [[ "$pline" =~ ^[a-z] && "$pline" != *"  "* && "$pline" == *":"* && "$pline" != "plan:"* ]]; then
          break
        fi
        # Phase line
        if echo "$pline" | grep -q "^  - phase:"; then
          ptotal=$((ptotal + 1))
          phase_has_pending=false
        fi
        # Task line
        if echo "$pline" | grep -q "^      - text:"; then
          ttotal=$((ttotal + 1))
        fi
        if echo "$pline" | grep -q "done: true"; then
          tdone=$((tdone + 1))
        elif echo "$pline" | grep -q "done: false"; then
          phase_has_pending=true
          if [[ -z "$next_task" ]]; then
            next_task=$(echo "$pline" | sed 's/.*text: //' | sed 's/^"//' | sed 's/"$//')
          fi
        fi
      done <<< "$track_yaml"

      # Count completed phases (all tasks done)
      local current_phase=0 current_phase_done=0 current_phase_tasks=0
      in_plan=false
      while IFS= read -r pline; do
        if [[ "$pline" == "plan:" ]]; then
          in_plan=true; continue
        fi
        [[ "$in_plan" != true ]] && continue
        if [[ "$pline" =~ ^[a-z] && "$pline" != *"  "* && "$pline" == *":"* && "$pline" != "plan:"* ]]; then
          break
        fi
        if echo "$pline" | grep -q "^  - phase:"; then
          if [[ "$current_phase" -gt 0 && "$current_phase_done" -eq "$current_phase_tasks" && "$current_phase_tasks" -gt 0 ]]; then
            pdone=$((pdone + 1))
          fi
          current_phase=$((current_phase + 1))
          current_phase_done=0
          current_phase_tasks=0
        fi
        if echo "$pline" | grep -q "done: true"; then
          current_phase_done=$((current_phase_done + 1))
          current_phase_tasks=$((current_phase_tasks + 1))
        elif echo "$pline" | grep -q "done: false"; then
          current_phase_tasks=$((current_phase_tasks + 1))
        fi
      done <<< "$track_yaml"
      # Last phase
      if [[ "$current_phase" -gt 0 && "$current_phase_done" -eq "$current_phase_tasks" && "$current_phase_tasks" -gt 0 ]]; then
        pdone=$((pdone + 1))
      fi
    fi

    active_ids+=("$tid")
    active_titles+=("$ttitle")
    active_types+=("$ttype")
    active_statuses+=("$tstatus")
    active_task_done+=("$tdone")
    active_task_total+=("$ttotal")
    active_phase_done+=("$pdone")
    active_phase_total+=("$ptotal")
    active_next_task+=("$next_task")
  done <<< "$tracks_content"

  # --- Deps data (for blockers, ready check, and per-track dep counts) ---
  local deps_content=""
  deps_content=$(_read_kf "tracks/deps.yaml")

  # Compute per-track dep counts and find ready tracks
  local -a ready_ids=()
  local -a active_dep_met=() active_dep_total=()
  for i in "${!active_ids[@]}"; do
    local tid="${active_ids[$i]}"
    local dep_total=0 dep_met=0
    local blocked=false

    if [[ -n "$deps_content" ]]; then
      local track_deps=""
      track_deps=$(echo "$deps_content" | awk -v id="$tid" '
        $0 ~ "^"id":" { found=1; next }
        found && /^  - / { print substr($0, 5); next }
        found { exit }
      ')
      if [[ -n "$track_deps" ]]; then
        while IFS= read -r dep; do
          [[ -z "$dep" ]] && continue
          dep_total=$((dep_total + 1))
          if echo "$tracks_content" | grep -q "^${dep}:.*\"status\":\"completed\""; then
            dep_met=$((dep_met + 1))
          else
            blocked=true
          fi
        done <<< "$track_deps"
      fi
    fi

    active_dep_met+=("$dep_met")
    active_dep_total+=("$dep_total")

    if [[ "${active_statuses[$i]}" == "pending" && "$blocked" == false ]]; then
      ready_ids+=("$tid")
    fi
  done

  # --- Total tasks across all active tracks ---
  local total_tasks_done=0 total_tasks_all=0
  for i in "${!active_ids[@]}"; do
    total_tasks_done=$((total_tasks_done + active_task_done[i]))
    total_tasks_all=$((total_tasks_all + active_task_total[i]))
  done

  # --- Claim detection for status display ---
  local claimed_cache=""
  claimed_cache=$(get_claimed_tracks 2>/dev/null || true)

  # --- Progress bar helper ---
  _progress_bar() {
    local done=$1 total=$2 width=20
    if [[ "$total" -eq 0 ]]; then
      printf "[....................] 0%%"
      return
    fi
    local pct=$((done * 100 / total))
    local filled=$((done * width / total))
    local empty=$((width - filled))
    printf "["
    for ((j=0; j<filled; j++)); do printf "#"; done
    for ((j=0; j<empty; j++)); do printf "."; done
    printf "] %d%%" "$pct"
  }

  # --- Output ---
  echo "================================================================================"
  printf "                        PROJECT STATUS: %s\n" "$project_name"
  echo "================================================================================"
  echo ""
  echo "--------------------------------------------------------------------------------"
  echo "                              OVERALL PROGRESS"
  echo "--------------------------------------------------------------------------------"
  echo ""
  local done_count=$((completed + archived))
  printf "Tracks:     %d/%d done (%d%%)\n" "$done_count" "$total" "$((total > 0 ? done_count * 100 / total : 0))"
  printf "Tasks:      %d/%d completed (active tracks)\n" "$total_tasks_done" "$total_tasks_all"
  echo ""
  printf "Progress:   "; _progress_bar "$done_count" "$total"; echo ""
  echo ""
  printf "  completed:   %4d\n" "$completed"
  printf "  in-progress: %4d\n" "$in_progress"
  printf "  pending:     %4d\n" "$pending"
  printf "  archived:    %4d\n" "$archived"
  echo ""

  # --- Track detail table ---
  if [[ "${#active_ids[@]}" -gt 0 ]]; then
    echo "--------------------------------------------------------------------------------"
    echo "                              ACTIVE TRACKS"
    echo "--------------------------------------------------------------------------------"
    echo ""
    printf "%-10s %-48s %-8s %-12s %s\n" "Status" "Track ID" "Type" "Tasks" "Deps"
    printf "%-10s %-48s %-8s %-12s %s\n" "----------" "------------------------------------------------" "--------" "------------" "----------"

    # Helper: format deps column
    _fmt_deps() {
      local met=$1 total=$2
      if [[ "$total" -eq 0 ]]; then
        echo "no deps"
      else
        echo "${met}/${total} met"
      fi
    }

    # Helper: resolve display status label
    _status_label() {
      local idx=$1
      if [[ "${active_statuses[$idx]}" == "in-progress" ]]; then
        echo "CLAIMED"
      elif [[ "${active_statuses[$idx]}" == "pending" ]]; then
        # Check if claimed via branch detection
        local tid="${active_ids[$idx]}"
        if [[ -n "$claimed_cache" ]]; then
          local claimer=""
          claimer=$(echo "$claimed_cache" | awk -F'\t' -v id="$tid" '$1 == id {print $2; exit}')
          if [[ -n "$claimer" ]]; then
            echo "CLAIMED"
            return
          elif echo "$claimed_cache" | awk -F'\t' -v id="$tid" '$1 == id {found=1; exit} END{exit !found}' 2>/dev/null; then
            echo "CLAIMED"
            return
          fi
        fi
        # Check if in ready list
        local is_ready=false
        for rid in "${ready_ids[@]}"; do
          [[ "$rid" == "${active_ids[$idx]}" ]] && is_ready=true && break
        done
        if [[ "$is_ready" == true ]]; then
          echo "AVAILABLE"
        else
          echo "BLOCKED"
        fi
      fi
    }

    # In-progress (CLAIMED) first
    for i in "${!active_ids[@]}"; do
      [[ "${active_statuses[$i]}" != "in-progress" ]] && continue
      local pct=0
      [[ "${active_task_total[$i]}" -gt 0 ]] && pct=$((active_task_done[i] * 100 / active_task_total[i]))
      printf "%-10s %-48s %-8s %-12s %s\n" \
        "$(_status_label $i)" "${active_ids[$i]}" "${active_types[$i]}" \
        "${active_task_done[$i]}/${active_task_total[$i]} (${pct}%)" \
        "$(_fmt_deps "${active_dep_met[$i]}" "${active_dep_total[$i]}")"
    done

    # Then pending (AVAILABLE / BLOCKED)
    for i in "${!active_ids[@]}"; do
      [[ "${active_statuses[$i]}" != "pending" ]] && continue
      local pct=0
      [[ "${active_task_total[$i]}" -gt 0 ]] && pct=$((active_task_done[i] * 100 / active_task_total[i]))
      printf "%-10s %-48s %-8s %-12s %s\n" \
        "$(_status_label $i)" "${active_ids[$i]}" "${active_types[$i]}" \
        "${active_task_done[$i]}/${active_task_total[$i]} (${pct}%)" \
        "$(_fmt_deps "${active_dep_met[$i]}" "${active_dep_total[$i]}")"
    done
    echo ""
  fi

  # --- Current focus ---
  echo "--------------------------------------------------------------------------------"
  echo "                              CURRENT FOCUS"
  echo "--------------------------------------------------------------------------------"
  echo ""

  local has_claimed=false
  # Show in-progress tracks
  for i in "${!active_ids[@]}"; do
    [[ "${active_statuses[$i]}" != "in-progress" ]] && continue
    has_claimed=true
    printf "Claimed: %s\n" "${active_ids[$i]}"
    printf "  Title: %s\n" "${active_titles[$i]}"
    printf "  Progress: %d/%d tasks, %d/%d phases\n" \
      "${active_task_done[$i]}" "${active_task_total[$i]}" \
      "${active_phase_done[$i]}" "${active_phase_total[$i]}"
    if [[ -n "${active_next_task[$i]}" ]]; then
      printf "  Next: %s\n" "${active_next_task[$i]}"
    fi
    echo ""
  done
  # Show branch-claimed pending tracks
  for i in "${!active_ids[@]}"; do
    [[ "${active_statuses[$i]}" != "pending" ]] && continue
    local tid="${active_ids[$i]}"
    [[ -z "$claimed_cache" ]] && continue
    local claimer=""
    claimer=$(echo "$claimed_cache" | awk -F'\t' -v id="$tid" '$1 == id {print $2; exit}')
    if [[ -n "$claimer" ]] || echo "$claimed_cache" | awk -F'\t' -v id="$tid" '$1 == id {found=1; exit} END{exit !found}' 2>/dev/null; then
      has_claimed=true
      local worker_info=""
      [[ -n "$claimer" ]] && worker_info=" (by ${claimer})"
      printf "Claimed%s: %s\n" "$worker_info" "${active_ids[$i]}"
      printf "  Title: %s\n" "${active_titles[$i]}"
      printf "  Progress: %d/%d tasks, %d/%d phases\n" \
        "${active_task_done[$i]}" "${active_task_total[$i]}" \
        "${active_phase_done[$i]}" "${active_phase_total[$i]}"
      if [[ -n "${active_next_task[$i]}" ]]; then
        printf "  Next: %s\n" "${active_next_task[$i]}"
      fi
      echo ""
    fi
  done

  if [[ "$has_claimed" == false ]]; then
    echo "No tracks currently in-progress."
    echo ""
  fi

  # --- Ready to start ---
  echo "--------------------------------------------------------------------------------"
  echo "                            READY TO START"
  echo "--------------------------------------------------------------------------------"
  echo ""
  local has_ready=false
  if [[ "${#ready_ids[@]}" -gt 0 ]]; then
    for rid in "${ready_ids[@]}"; do
      # Skip claimed tracks
      if [[ -n "$claimed_cache" ]]; then
        if echo "$claimed_cache" | awk -F'\t' -v id="$rid" '$1 == id {found=1; exit} END{exit !found}' 2>/dev/null; then
          continue
        fi
      fi
      for i in "${!active_ids[@]}"; do
        if [[ "${active_ids[$i]}" == "$rid" ]]; then
          printf "  %s — %s\n" "$rid" "${active_titles[$i]}"
          has_ready=true
          break
        fi
      done
    done
  fi
  if [[ "$has_ready" == false ]]; then
    echo "  (none — all ready tracks are claimed or have unmet dependencies)"
  fi
  echo ""

  # --- Conflict Risk section ---
  local conflicts_content=""
  conflicts_content=$(_read_kf "tracks/conflicts.yaml")

  # Filter to pairs where both tracks are active
  local -a conflict_pairs=() conflict_risks=() conflict_notes=()
  if [[ -n "$conflicts_content" ]]; then
    while IFS= read -r cline; do
      [[ -z "$cline" || "$cline" == \#* ]] && continue
      # Format: id-a/id-b: {"risk":"...","note":"...","added":"..."}
      local pair_key pair_json
      pair_key=$(echo "$cline" | sed 's/:.*//')
      pair_json=$(echo "$cline" | sed 's/^[^{]*//')
      local id_a id_b
      id_a=$(echo "$pair_key" | cut -d'/' -f1)
      id_b=$(echo "$pair_key" | cut -d'/' -f2)

      # Check both tracks are active
      local a_active=false b_active=false
      for aid in "${active_ids[@]}"; do
        [[ "$aid" == "$id_a" ]] && a_active=true
        [[ "$aid" == "$id_b" ]] && b_active=true
      done
      [[ "$a_active" != true || "$b_active" != true ]] && continue

      local crisk cnote
      if command -v jq &>/dev/null; then
        crisk=$(echo "$pair_json" | jq -r '.risk // "unknown"')
        cnote=$(echo "$pair_json" | jq -r '.note // ""')
      else
        crisk=$(echo "$pair_json" | grep -o '"risk":"[^"]*"' | head -1 | sed 's/"risk":"\(.*\)"/\1/')
        cnote=$(echo "$pair_json" | grep -o '"note":"[^"]*"' | head -1 | sed 's/"note":"\(.*\)"/\1/')
      fi

      conflict_pairs+=("${id_a}/${id_b}")
      conflict_risks+=("$crisk")
      conflict_notes+=("$cnote")
    done <<< "$conflicts_content"
  fi

  if [[ "${#conflict_pairs[@]}" -gt 0 ]]; then
    echo "--------------------------------------------------------------------------------"
    echo "                              CONFLICT RISK"
    echo "--------------------------------------------------------------------------------"
    echo ""
    for i in "${!conflict_pairs[@]}"; do
      # Truncate note to 80 chars
      local note="${conflict_notes[$i]}"
      if [[ "${#note}" -gt 80 ]]; then
        note="${note:0:77}..."
      fi
      printf "  %-60s [%s]\n" "${conflict_pairs[$i]}" "${conflict_risks[$i]}"
      if [[ -n "$note" ]]; then
        printf "    %s\n" "$note"
      fi
    done
    echo ""
  fi

  # --- Blocked tracks (pending with unmet deps) ---
  local -a blocked_ids=() blocked_reasons=()
  for i in "${!active_ids[@]}"; do
    [[ "${active_statuses[$i]}" != "pending" ]] && continue
    local tid="${active_ids[$i]}"
    # Skip if already in ready list
    local is_ready=false
    for rid in "${ready_ids[@]}"; do
      [[ "$rid" == "$tid" ]] && is_ready=true && break
    done
    [[ "$is_ready" == true ]] && continue

    # Find unmet deps
    local unmet=""
    if [[ -n "$deps_content" ]]; then
      local track_deps=""
      track_deps=$(echo "$deps_content" | awk -v id="$tid" '
        $0 ~ "^"id":" { found=1; next }
        found && /^  - / { print substr($0, 5); next }
        found { exit }
      ')
      while IFS= read -r dep; do
        [[ -z "$dep" ]] && continue
        if ! echo "$tracks_content" | grep -q "^${dep}:.*\"status\":\"completed\""; then
          # Get dep status
          local dep_status="unknown"
          local dep_line
          dep_line=$(echo "$tracks_content" | grep "^${dep}:" | head -1)
          if [[ -n "$dep_line" ]]; then
            dep_status=$(echo "$dep_line" | grep -o '"status":"[^"]*"' | head -1 | sed 's/"status":"\(.*\)"/\1/')
          fi
          if [[ -n "$unmet" ]]; then
            unmet+=", "
          fi
          unmet+="${dep} (${dep_status})"
        fi
      done <<< "$track_deps"
    fi

    if [[ -n "$unmet" ]]; then
      blocked_ids+=("$tid")
      blocked_reasons+=("$unmet")
    fi
  done

  if [[ "${#blocked_ids[@]}" -gt 0 ]]; then
    echo "--------------------------------------------------------------------------------"
    echo "                           BLOCKED (unmet deps)"
    echo "--------------------------------------------------------------------------------"
    echo ""
    for i in "${!blocked_ids[@]}"; do
      printf "  %s\n" "${blocked_ids[$i]}"
      printf "    waiting on: %s\n" "${blocked_reasons[$i]}"
    done
    echo ""
  fi

  echo "================================================================================"
}

# --- Config settings ---
# Known settings: key|type|default
_CONFIG_SCHEMA=(
  "primary_branch|string|main"
  "enforce_dep_ordering|bool|true"
)
CONFIG_FILE="${KF_DIR}/config.yaml"

# Read a config value, applying default if missing.
_config_get_value() {
  local key="$1"
  local default_val=""
  local type=""
  for entry in "${_CONFIG_SCHEMA[@]}"; do
    local k t d
    k="${entry%%|*}"
    local rest="${entry#*|}"
    t="${rest%%|*}"
    d="${rest#*|}"
    if [[ "$k" == "$key" ]]; then
      default_val="$d"
      type="$t"
      break
    fi
  done

  if [[ -z "$type" ]]; then
    echo "ERROR: Unknown config key: $key" >&2
    return 1
  fi

  if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "$default_val"
    return 0
  fi

  # Read value from YAML (flat key: value format)
  local val
  val=$(grep "^${key}:" "$CONFIG_FILE" 2>/dev/null | head -1 | sed "s/^${key}:[[:space:]]*//" | sed 's/[[:space:]]*$//')
  if [[ -z "$val" ]]; then
    echo "$default_val"
  else
    echo "$val"
  fi
}

cmd_config() {
  local subcmd="${1:-}"; shift || true
  case "$subcmd" in
    list) _config_list "$@" ;;
    get)  _config_get "$@" ;;
    set)  _config_set "$@" ;;
    *)
      echo "Usage: kf-track config <list|get|set>" >&2
      echo "" >&2
      echo "  list                   Show all settings with current values and defaults" >&2
      echo "  get <key>              Get a single setting value" >&2
      echo "  set <key> <value>      Set a setting value" >&2
      return 1
      ;;
  esac
}

_config_list() {
  for entry in "${_CONFIG_SCHEMA[@]}"; do
    local k t d
    k="${entry%%|*}"
    local rest="${entry#*|}"
    t="${rest%%|*}"
    d="${rest#*|}"
    local current
    current=$(_config_get_value "$k")
    echo "${k}: ${current} (default: ${d})"
  done
}

_config_get() {
  local key="${1:-}"
  if [[ -z "$key" ]]; then
    echo "Usage: kf-track config get <key>" >&2
    return 1
  fi
  _config_get_value "$key"
}

_config_set() {
  local key="${1:-}" value="${2:-}"
  if [[ -z "$key" || -z "$value" ]]; then
    echo "Usage: kf-track config set <key> <value>" >&2
    return 1
  fi

  # Validate key exists in schema
  local type="" found=false
  for entry in "${_CONFIG_SCHEMA[@]}"; do
    local k t d
    k="${entry%%|*}"
    local rest="${entry#*|}"
    t="${rest%%|*}"
    d="${rest#*|}"
    if [[ "$k" == "$key" ]]; then
      type="$t"
      found=true
      break
    fi
  done

  if [[ "$found" != "true" ]]; then
    echo "ERROR: Unknown config key: $key" >&2
    echo "Known keys:" >&2
    for entry in "${_CONFIG_SCHEMA[@]}"; do
      echo "  ${entry%%|*}" >&2
    done
    return 1
  fi

  # Type validation
  if [[ "$type" == "bool" ]]; then
    case "$value" in
      true|false) ;;
      *)
        echo "ERROR: ${key} must be a boolean (true|false), got: $value" >&2
        return 1
        ;;
    esac
  fi

  # Create config file if it doesn't exist
  if [[ ! -f "$CONFIG_FILE" ]]; then
    cat > "$CONFIG_FILE" <<'HEADER'
# Kiloforge Project Configuration
#
# SCHEMA:
#   primary_branch: string (default: "main")
#     The branch agents read track state from.
#
#   enforce_dep_ordering: bool (default: true)
#     When true, the work queue scheduler skips tracks with unmet dependencies
#     and continues to the next eligible track (drain-loop). When false, tracks
#     are popped in order regardless of dependency status.
#
# Structured project settings used by kf tooling and agent skills.
# TOOL: Managed by `kf-track config` and agent skills. Hand-editable.

HEADER
  fi

  # Update or add the key
  if grep -q "^${key}:" "$CONFIG_FILE" 2>/dev/null; then
    sedi "s/^${key}:.*/${key}: ${value}/" "$CONFIG_FILE"
  else
    echo "${key}: ${value}" >> "$CONFIG_FILE"
  fi

  echo "Set ${key} = ${value}"
}

# --- Stash branch management ---

cmd_stash() {
  local subcmd="${1:-}"; shift || true
  case "$subcmd" in
    list)
      local track_id="${1:-}"
      local pattern
      if [[ -n "$track_id" ]]; then
        pattern="stash/${track_id}/*"
      else
        pattern="stash/*"
      fi
      local branches
      branches=$(git branch --list "$pattern" 2>/dev/null | sed 's/^[* ]*//' || true)
      if [[ -z "$branches" ]]; then
        echo "(no stash branches found)"
        return 0
      fi
      printf "%-60s %-30s %-15s %s\n" "BRANCH" "TRACK" "WORKER" "DATE"
      while IFS= read -r branch; do
        local track worker date_str
        track=$(echo "$branch" | cut -d'/' -f2)
        worker=$(echo "$branch" | cut -d'/' -f3-)
        date_str=$(git log -1 --format='%ci' "$branch" 2>/dev/null | cut -d' ' -f1 || echo "unknown")
        printf "%-60s %-30s %-15s %s\n" "$branch" "$track" "$worker" "$date_str"
      done <<< "$branches"
      ;;
    save)
      local track_id="${1:-}"
      if [[ -z "$track_id" ]]; then
        echo "Usage: kf-track stash save <track-id>" >&2; return 1
      fi
      # Determine worker name from worktree folder name or current branch
      local worker_name
      worker_name=$(basename "$(pwd)")
      if [[ ! "$worker_name" =~ ^worker- ]]; then
        worker_name=$(git branch --show-current 2>/dev/null || echo "unknown")
      fi
      local stash_branch="stash/${track_id}/${worker_name}"
      # Auto-commit any uncommitted changes
      if ! git diff --quiet HEAD 2>/dev/null || ! git diff --cached --quiet HEAD 2>/dev/null; then
        git add -A
        git commit -m "wip: auto-stash for ${track_id}" --no-verify 2>/dev/null || true
      fi
      git branch -f "$stash_branch" HEAD
      echo "Stash branch created: ${stash_branch}"
      ;;
    clean)
      local track_id="${1:-}"
      if [[ -z "$track_id" ]]; then
        echo "Usage: kf-track stash clean <track-id>" >&2; return 1
      fi
      local branches count=0
      branches=$(git branch --list "stash/${track_id}/*" 2>/dev/null | sed 's/^[* ]*//' || true)
      if [[ -z "$branches" ]]; then
        echo "(no stash branches for ${track_id})"
        return 0
      fi
      while IFS= read -r branch; do
        git branch -D "$branch" 2>/dev/null && ((count++)) || true
      done <<< "$branches"
      echo "Deleted ${count} stash branch(es) for ${track_id}"
      ;;
    *)
      echo "Usage: kf-track stash <list|save|clean> [track-id]" >&2
      return 1
      ;;
  esac
}

cmd_help() {
  cat <<'HELP'
kf-track — Track registry management for Kiloforge agents

USAGE:
  kf-track <command> [arguments]

COMMANDS:
  add <id> --title "..." [--type ...] [--deps "a,b"]   Add a new track
  update <id> --status <status>                         Update track status
  set <id> --<field> <value>                            Set arbitrary metadata field
  get <id> [--ref <branch|commit>]                       Show track details + deps
  archive <id> [reason]                                 Archive a track

  list [options]                                        List tracks (default: ready)
    --ready           Active tracks with all deps satisfied (default)
    --active          All pending + in-progress tracks
    --status <s>      Filter by exact status
    --all             Show all tracks including completed/archived
    --json            Output as JSON lines
    --ids             Output track IDs only
    --ref <ref>       Read from a git branch or commit

  show <id> [--section spec|plan|extra|header] [--json]   Show track content
  spec <id> [--field F] [--set "val"]                    Read/write spec fields
  plan <id> [--phase N]                                  Show implementation plan
  task <id> <phase.task> --done|--pending                Update task completion
  progress <id> [--json]                                 Show track completion stats
  extra <id> [--key K] [--set "val"|--delete]            Read/write extra metadata
  init <id> --title "..." [--type ...] [--spec-file ...] Create track.yaml
  migrate <id> [--force] [--keep]                        Convert legacy files to track.yaml
  migrate-all [--force] [--keep] [--dry-run]             Convert all legacy tracks

  compact [run] [--dry-run]                              Compact completed/archived tracks
  compact list [--json]                                  Show compaction history
  compact recover <hash>                                 Show recovery commands for a compaction
  compact import <hash> [--source ...] [--note ...]      Import legacy compaction record

  deps add <id> <dep-id>                                Add a dependency
  deps remove <id> <dep-id>                             Remove a dependency
  deps list <id>                                        List dependencies
  deps check <id>                                       Check if all deps satisfied

  conflicts add <a> <b> [risk] [note]                   Add conflict risk pair
  conflicts remove <a> <b>                              Remove conflict pair
  conflicts list [track-id]                             List pairs (filtered)
  conflicts clean                                       Remove pairs for completed tracks

  stash list [track-id]                                 List stash branches
  stash save <track-id>                                 Save current work to stash branch
  stash clean <track-id>                                Delete stash branches for a track

  status [--ref <branch|commit>]                          Full project status report
  index [--ref <branch|commit>]                          Generate project index from tracks.yaml
  config list                                            List all project settings
  config get <key>                                       Get a setting value
  config set <key> <value>                               Set a setting value

  quick-links [show [--ref <ref>]]                       Show quick links
  quick-links add <label> <path>                         Add a quick link
  quick-links remove <label>                             Remove a quick link

STATUS VALUES:
  pending       Track created, not yet started
  in-progress   Track claimed by a developer
  completed     Track implementation done
  archived      Track moved to archive

EXAMPLES:
  kf-track add my-track_20260310Z --title "My Feature" --type feature
  kf-track update my-track_20260310Z --status in-progress
  kf-track list --status pending
  kf-track list --all
  kf-track deps check my-track_20260310Z
  kf-track archive my-track_20260310Z "completed and merged"
HELP
}

# --- Main dispatch ---
cmd="${1:-help}"; shift || true
case "$cmd" in
  add)     cmd_add "$@" ;;
  update)  cmd_update "$@" ;;
  set)     cmd_set "$@" ;;
  get)     cmd_get "$@" ;;
  list)    cmd_list "$@" ;;
  archive) cmd_archive "$@" ;;
  compact) cmd_compact "$@" ;;
  deps)        cmd_deps "$@" ;;
  conflicts)   cmd_conflicts "$@" ;;
  stash)       cmd_stash "$@" ;;
  index)       cmd_index "$@" ;;
  quick-links) cmd_quick_links "$@" ;;
  status)      cmd_status "$@" ;;
  config)      cmd_config "$@" ;;
  # Content commands delegate to kf-track-content (Python3 required)
  show|spec|plan|task|progress|extra|init|migrate|migrate-all)
    cmd_content "$cmd" "$@" ;;
  help|--help|-h) cmd_help ;;
  *)       echo "Unknown command: $cmd. Run 'kf-track help' for usage." >&2; exit 1 ;;
esac
